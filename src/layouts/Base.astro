---
import PostHog from '../components/posthog.astro';

interface Props {
  title?: string;
  description?: string;
  ogType?: string;
  canonicalURL?: string;
  noindex?: boolean;
}

const {
  title = 'Jocy Wolff, Senior Software Engineer',
  description = 'A webview version of the CV PDF',
  ogType = 'website',
  canonicalURL = Astro.url.href,
  noindex = false,
} = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#324f41" />
    <meta name="author" content="Jocy Wolff" />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonicalURL} />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content="https://jocywolff.com/profilePicture.png" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://jocywolff.com/profilePicture.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <title>{title}</title>
    <PostHog />
  </head>
  <body>
    <slot />
  </body>
</html>
